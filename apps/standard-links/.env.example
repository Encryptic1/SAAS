# Standard Links environment variables
# Copy to .env.local and fill in.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3007

# Supabase (shared project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (shared account)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LINKS_STARTER=price_1TnJYbIJbuHvnqyqiXbHRPPr

# Suite siblings (for cross-app navigation)
NEXT_PUBLIC_METRICS_URL=http://localhost:3003

# Cron (for /api/cron/* routes if added later)
CRON_SECRET=

# Local dev flag — set automatically by `pnpm dev:local`
# NEXT_PUBLIC_LOCAL_DEV=true
