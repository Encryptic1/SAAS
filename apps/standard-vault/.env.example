# Standard Vault environment variables
# Copy to .env.local and fill in.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3006

# Supabase (shared project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (shared account)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_VAULT_STARTER=price_1TnJYbIJbuHvnqyqmw7lwJ6p

# Vault master encryption key — 32-byte hex (64 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In local dev, if unset, a deterministic local key is derived automatically.
VAULT_MASTER_KEY=

# GitHub Actions sync (optional — leave blank to disable)
GITHUB_TOKEN=

# Suite siblings (for cross-app navigation)
NEXT_PUBLIC_METRICS_URL=http://localhost:3003
NEXT_PUBLIC_PROOF_URL=http://localhost:3002

# Cron (for /api/cron/* routes if added later)
CRON_SECRET=

# Local dev flag — set automatically by `pnpm dev:local`
# NEXT_PUBLIC_LOCAL_DEV=true
