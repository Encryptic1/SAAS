{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/cron/standup",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/standup-digest",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 8 * * *"
    }
  ]
}
