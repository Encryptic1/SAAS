# =============================================================================
# Market Standard, LLC — Shared environment template
# Copy to .env.local per app or use Vercel env groups
# =============================================================================

# Local PGlite (via socket server on port 54322)
DATABASE_URL=postgresql://127.0.0.1:54322/postgres
PGLITE_PORT=54322

# Stripe (shared account, per-app products/prices)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Per-app Stripe price IDs (set in each app's Vercel project, lookup_key-driven)
# Created via Stripe MCP — live mode price IDs for the Market Standard portfolio.
STRIPE_PRICE_POLLS_STARTER=price_1TnJXtIJbuHvnqyqW0eVfddv
STRIPE_PRICE_POLLS_GROWTH=price_1TnJXtIJbuHvnqyqJnZoG49R
STRIPE_PRICE_PROOF_STARTER=price_1TnJYbIJbuHvnqyqpbmGqFlP
STRIPE_PRICE_PROOF_GROWTH=price_1TnJYbIJbuHvnqyqbBHVdrhg
STRIPE_PRICE_METRICS_STARTER=price_1TnJYbIJbuHvnqyqWEWdX7yS
STRIPE_PRICE_METRICS_GROWTH=price_1TnJYbIJbuHvnqyqX1sWlCM8
STRIPE_PRICE_HOOK_STARTER=price_1TnJYbIJbuHvnqyqhiuPP0YN
STRIPE_PRICE_RELEASE_STARTER=price_1TnJYcIJbuHvnqyqtyJ2Jpq8
